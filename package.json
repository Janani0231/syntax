{
  "name": "syntax-homepage",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "build": "vite build",
    "build:full": "npm run build && npm run server:build",
    "preview": "vite preview",
    "server:dev": "npm --prefix server run dev",
    "server:worker:dev": "npm --prefix server run worker:dev",
    "server:build": "npm --prefix server run build",
    "server:start": "npm --prefix server run start",
    "server:worker:start": "npm --prefix server run worker:start",
    "start:full": "npm run build:full && npm run server:start"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  }
}
